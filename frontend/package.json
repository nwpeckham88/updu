{
	"name": "frontend",
	"private": true,
	"version": "0.2.8-beta",
	"type": "module",
	"scripts": {
		"dev": "vite dev",
		"build": "vite build",
		"preview": "vite preview",
		"test": "pnpm check",
		"test:e2e": "pnpm run test:e2e:prepare && playwright test",
		"test:e2e:headed": "pnpm run test:e2e:prepare && playwright test --headed",
		"test:e2e:debug": "pnpm run test:e2e:prepare && playwright test --debug",
		"test:e2e:report": "playwright show-report",
		"test:e2e:install": "playwright install --with-deps chromium",
		"test:e2e:prepare": "bash ./e2e/scripts/prepare-app.sh",
		"prepare": "svelte-kit sync || echo ''",
		"check": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
		"check:watch": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json --watch"
	},
	"devDependencies": {
		"@playwright/test": "^1.55.0",
		"@sveltejs/adapter-auto": "^7.0.1",
		"@sveltejs/adapter-static": "^3.0.10",
		"@sveltejs/kit": "^2.53.4",
		"@sveltejs/vite-plugin-svelte": "^7.0.0",
		"@tailwindcss/vite": "^4.2.1",
		"svelte": "^5.53.7",
		"svelte-check": "^4.4.4",
		"tailwindcss": "^4.2.1",
		"typescript": "^5.9.3",
		"vite": "^7.3.1"
	},
	"dependencies": {
		"bits-ui": "^2.16.3",
		"clsx": "^2.1.1",
		"date-fns": "^4.1.0",
		"layerchart": "^1.0.13",
		"lucide-svelte": "^0.575.0",
		"tailwind-merge": "^3.5.0"
	}
}