# Example environment file for updu.
# Copy to `.env` and fill in real values. Never commit `.env`.
# All variables are optional unless marked REQUIRED.

# ── Server ────────────────────────────────────────────────
UPDU_HOST=0.0.0.0
UPDU_PORT=3000
UPDU_BASE_URL=http://localhost:3000
UPDU_BASE_PATH=

# ── Storage ───────────────────────────────────────────────
UPDU_DB_PATH=/data/updu.db

# ── Config sources ────────────────────────────────────────
# Path to a YAML config file (e.g. updu.conf). See sample.updu.conf.
UPDU_CONF_PATH=
# Or fetch the config from a URL on startup.
UPDU_CONF_URL=
# Legacy alias for UPDU_CONF_PATH.
UPDU_CONFIG_PATH=

# ── Authentication (REQUIRED in production) ───────────────
# Random 32+ byte secret used to sign sessions. Generate with:
#   openssl rand -hex 32
UPDU_AUTH_SECRET=
UPDU_SESSION_TTL_DAYS=7
UPDU_PASSWORD_POLICY=strong

# Bootstrap admin (created on first run if no users exist).
UPDU_ADMIN_USER=
UPDU_ADMIN_PASSWORD=

# ── OIDC (optional) ───────────────────────────────────────
UPDU_OIDC_ISSUER=
UPDU_OIDC_CLIENT_ID=
UPDU_OIDC_CLIENT_SECRET=
UPDU_OIDC_REDIRECT_URL=
UPDU_OIDC_AUTO_REGISTER=false

# ── Networking / proxies ──────────────────────────────────
# Comma-separated CIDRs whose X-Forwarded-* headers are trusted.
UPDU_TRUSTED_PROXY_CIDRS=
# Allow monitors to target localhost / loopback addresses.
UPDU_ALLOW_LOCALHOST=false

# ── Worker pool ───────────────────────────────────────────
UPDU_WORKER_POOL_SIZE=4
UPDU_MIN_INTERVAL_S=30

# ── Observability ─────────────────────────────────────────
UPDU_LOG_LEVEL=info
# Bearer token required to scrape /metrics. Leave blank to disable auth.
UPDU_METRICS_TOKEN=

# ── UI ────────────────────────────────────────────────────
UPDU_ENABLE_CUSTOM_CSS=false

# ── Updater (advanced) ────────────────────────────────────
# Override the GitHub releases API endpoint used for self-update checks.
UPDU_RELEASES_API_URL=
